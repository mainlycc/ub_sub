# Database
# PostgreSQL connection string
# For local development (with Docker):
# DATABASE_URL="postgresql://username:password@localhost:5432/ubepapi_db"

# For Vercel deployment, use Vercel Postgres or external PostgreSQL:
# DATABASE_URL="postgresql://username:password@host:5432/database_name?sslmode=require"

# For local development with Docker:
DATABASE_URL="postgresql://postgres:password@localhost:5432/ubepapi_db"

# Admin credentials
# WYMAGANE: Ustaw te zmienne w .env.local (nie commituj ich do repozytorium!)
# Aby wygenerować hash hasła, uruchom: node scripts/generate-password-hash.js <twoje_hasło>
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# JWT Secret
# WYMAGANE: Wygeneruj bezpieczny losowy string (np. openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here

# GAP API credentials
GAP_API_USERNAME=your_gap_api_username
GAP_API_PASSWORD=your_gap_api_password
GAP_SELLER_NODE_CODE=your_seller_node_code

# Environment
NODE_ENV=development
